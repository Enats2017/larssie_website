  acti_gold_price         Decimal? @db.Decimal(10, 2)
  acti_gold_min_amount    Decimal? @db.Decimal(10, 2)
  acti_gold_refund_with_justification    String? @db.VarChar(255)
  acti_gold_refund_without_justification String? @db.VarChar(255)
  acti_gold_deadline_for_refund_with_justification    String? @db.VarChar(255)
  acti_gold_deadline_for_refund_without_justification String? @db.VarChar(255)

