  hide_qty_for_option String @db.VarChar(255)
  type           String   @db.VarChar(255)
  reg_list_url   String   @db.VarChar(255)
  last_min_reg_list_url String @db.VarChar(255)
  sku            String   @db.VarChar(64)
  upc            String   @db.VarChar(12)
  ean            String   @db.VarChar(14)
