}
model CourseBuilder {
  course_id         Int      @id @default(autoincrement())
  brand_id          Int
  event_id          Int
  distance_id       String?  @db.VarChar(100)

  title_word        String?  @db.VarChar(100)
  title_script      String?  @db.VarChar(100)

  tech_name         String?  @db.VarChar(100)
  tech_icon         String?  @db.VarChar(255)
  tech_stars        Int?     @default(0) @db.TinyInt
  tech_label        String?  @db.VarChar(255)

  terrain_name      String?  @db.VarChar(100)
  terrain_icon      String?  @db.VarChar(255)
  terrain_line1     String?  @db.VarChar(255)
  terrain_line2     String?  @db.VarChar(255)

  metric1_name      String?  @db.VarChar(255)
  metric1_icon      String?  @db.VarChar(255)
  metric1_sub_label String?  @db.VarChar(255)
  metric1_value     String?  @db.VarChar(255)

  metric2_name      String?  @db.VarChar(255)
  metric2_icon      String?  @db.VarChar(255)
  metric2_sub_label String?  @db.VarChar(255)
  metric2_value     String?  @db.VarChar(255)

  metric3_name      String?  @db.VarChar(255)
  metric3_icon      String?  @db.VarChar(255)
  metric3_sub_label String?  @db.VarChar(255)
  metric3_value     String?  @db.VarChar(255)

  metric4_name      String?  @db.VarChar(255)
  metric4_icon      String?  @db.VarChar(255)
  metric4_sub_label String?  @db.VarChar(255)
  metric4_value     String?  @db.VarChar(255)

  created_at        DateTime? @default(now())
  updated_at        DateTime? @updatedAt

  description    String?  @db.Text
  description_nl String?  @db.Text
  description_fr String?  @db.Text

  title_word_nl   String?  @db.VarChar(100)
  title_word_fr   String?  @db.VarChar(100)
  title_script_nl String?  @db.VarChar(100)
  title_script_fr String?  @db.VarChar(100)
  tech_name_nl    String?  @db.VarChar(100)
  tech_name_fr    String?  @db.VarChar(100)
  tech_label_nl   String?  @db.VarChar(255)
  tech_label_fr   String?  @db.VarChar(255)
  terrain_name_nl  String? @db.VarChar(100)
  terrain_name_fr  String? @db.VarChar(100)
  terrain_line1_nl String? @db.VarChar(255)
  terrain_line1_fr String? @db.VarChar(255)
  terrain_line2_nl String? @db.VarChar(255)
  terrain_line2_fr String? @db.VarChar(255)
  metric1_name_nl  String? @db.VarChar(255)
  metric1_name_fr  String? @db.VarChar(255)
  metric1_sub_nl   String? @db.VarChar(255)
  metric1_sub_fr   String? @db.VarChar(255)
  metric1_value_nl String? @db.VarChar(255)
  metric1_value_fr String? @db.VarChar(255)
  metric2_name_nl  String? @db.VarChar(255)
  metric2_name_fr  String? @db.VarChar(255)
  metric2_sub_nl   String? @db.VarChar(255)
  metric2_sub_fr   String? @db.VarChar(255)
  metric2_value_nl String? @db.VarChar(255)
  metric2_value_fr String? @db.VarChar(255)
  metric3_name_nl  String? @db.VarChar(255)
  metric3_name_fr  String? @db.VarChar(255)
  metric3_sub_nl   String? @db.VarChar(255)
  metric3_sub_fr   String? @db.VarChar(255)
  metric3_value_nl String? @db.VarChar(255)
  metric3_value_fr String? @db.VarChar(255)
  metric4_name_nl  String? @db.VarChar(255)
  metric4_name_fr  String? @db.VarChar(255)
  metric4_sub_nl   String? @db.VarChar(255)
  metric4_sub_fr   String? @db.VarChar(255)
  metric4_value_nl String? @db.VarChar(255)
  metric4_value_fr String? @db.VarChar(255)

  @@index([brand_id])
  @@index([event_id])
  @@map("course_builder")
}

model CourseLinkCards {
  card_id    Int       @id @default(autoincrement())
  course_id  Int
  card_title String?   @db.VarChar(255)
  card_title_nl String?   @db.VarChar(255)
  card_title_fr String?   @db.VarChar(255)
  card_image String?   @db.LongText
  card_url   String?   @db.Text
  sort_order Int?      @default(0)
  created_at DateTime? @default(now())

  @@index([course_id])
  @@map("course_link_cards")
}
enum InfoBuilderLayoutType {
  side
  side_left @map("side-left")
  background
}

enum InfoBuilderMediaType {
  image
  video
}

model InfoBuilder {
  info_id     Int      @id @default(autoincrement())
  brand_id    Int
  event_id    Int
  distance_id Int?
  sort_order  Int      @default(0)

  tagline     String   @db.VarChar(150)
  title       String   @db.VarChar(150)
  alt_label   String   @default("ALTITUDE") @db.VarChar(100)
  altitude    String   @db.VarChar(100)
  description String?  @db.Text

  cta_text    String   @db.VarChar(150)
  cta_link    String   @db.VarChar(500)

  faq_link    String   @db.VarChar(500)
  faq_text    String   @default("FREQUENTLY ASKED QUESTIONS") @db.VarChar(150)
  faq_icon    String   @default("fa-question-circle") @db.VarChar(100)

  layout_type InfoBuilderLayoutType? @default(side)
  media_type  InfoBuilderMediaType   @default(image)

  image_path  String   @db.VarChar(500)
  video_path  String   @db.VarChar(500)
  video_url   String   @db.VarChar(500)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([brand_id])
  @@index([event_id])
  @@index([distance_id])
  @@map("info_builder")
}

model gearup_builder {
  gearup_id          Int      @id @default(autoincrement())
  brand_id           Int
  event_id           Int
  distance_id        Int
  title_word         String?  @db.VarChar(255)
  title_script       String?  @db.VarChar(255)
  mandatory_title    String?  @db.VarChar(255)
  mandatory_desc     String?  @db.Text
  mandatory_icon     String?  @db.VarChar(255)
  recommended_title  String?  @db.VarChar(255)
  recommended_desc   String?  @db.Text
  recommended_icon   String?  @db.VarChar(255)
  mandatory_items    String?  @db.LongText
  recommended_items  String?  @db.LongText
  created_at         DateTime? @default(now())
  updated_at         DateTime? @updatedAt
  gearup_link_cards  gearup_link_cards[]

  @@index([event_id, distance_id])
}

model gearup_link_cards {
  card_id        Int    @id @default(autoincrement())
  gearup_id      Int
  card_title     String? @db.VarChar(255)
  card_image     String? @db.VarChar(500)
  card_url       String? @db.VarChar(500)
  sort_order     Int     @default(0)
  gearup_builder gearup_builder @relation(fields: [gearup_id], references: [gearup_id])
}

model sponsor_builder {
  sponsor_id   Int      @id @default(autoincrement())
  brand_id     Int
  event_id     Int
  distance_id  String   @db.VarChar(100)
  title_word   String?  @db.VarChar(255)
  title_script String?  @db.VarChar(255)
  description  String?  @db.Text
  created_at   DateTime? @default(now())
  updated_at   DateTime? @updatedAt

  sponsor_logos sponsor_logos[]

  @@index([event_id, brand_id, distance_id])
}

model sponsor_logos {
  logo_id         Int      @id @default(autoincrement())
  sponsor_id      Int
