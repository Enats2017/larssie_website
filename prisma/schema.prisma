  acti_basic_min_amount    Decimal? @db.Decimal(10, 2)
  acti_basic_refund_with_justification    String? @db.VarChar(255)
  acti_basic_refund_without_justification String? @db.VarChar(255)
  acti_basic_deadline_for_refund_with_justification    String? @db.VarChar(255)
  acti_basic_deadline_for_refund_without_justification String? @db.VarChar(255)

  acti_premium_price_type    String?  @db.VarChar(255)
  acti_premium_price         Decimal? @db.Decimal(10, 2)
  acti_premium_min_amount    Decimal? @db.Decimal(10, 2)
  acti_premium_refund_with_justification    String? @db.VarChar(255)
  acti_premium_refund_without_justification String? @db.VarChar(255)
  acti_premium_deadline_for_refund_with_justification    String? @db.VarChar(255)
  acti_premium_deadline_for_refund_without_justification String? @db.VarChar(255)

