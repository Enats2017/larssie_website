  date_added     DateTime @db.DateTime(0)
  date_modified  DateTime @db.DateTime(0)
  archive_status Int
  live_result_url String  @default("") @db.VarChar(255)
  category_page_image String @default("") @db.VarChar(255)
  participant_list Int
  affiliate_link Int
  medical_waiver Int      @default(0)
  medical_waiver_upload_date DateTime @db.Date
  separate_telephone Int  @default(0)
  acti_annulation Int     @default(0)
  no_participant Int      @default(0)
  product_country_id Int  @default(0)
  product_zone_id Int     @default(0)
  product_country_manager_id Int @default(0)
  medical_waiver_accept_reject Int @default(11)
  handling_fee_discount Decimal @default(0) @db.Decimal(15, 4)
  handling_fee_fixed Decimal @default(0) @db.Decimal(15, 4)
  custom_mail_type Int    @default(0)
  group_registration Int  @default(0)
  who_can_create_group Int @default(0)
  payment_method Int      @default(0)
  is_used        Int      @default(0)
  date_is_used   DateTime @db.DateTime(0)
  is_used_user_id Int     @default(0)
  annulation_updated Int  @default(0)
  old_product_id Int      @default(0)
  product_name   String   @default("") @db.VarChar(255)
  generate_qr_codes Int   @default(0)
  start_date_reg_members DateTime @db.Date
  end_date_members DateTime @db.Date
  change_date_members DateTime @db.Date
  refund_module_for_this_event Int @default(0)
  refund_method  Int      @default(0)
  handling_fee_per_cash_refund Decimal @default(0) @db.Decimal(15, 4)
  handling_fee_refund_will_be_paid Int @default(0)
  refund_start_date DateTime @db.Date
  refund_end_date DateTime @db.Date
  refund_admin_fee Int     @default(0)
  refund_acti    Int       @default(0)
  refund_rules   String    @db.Text
  custom_start_date DateTime @db.Date
  last_day_participants_cancel_registration DateTime @db.Date
  last_day_members_cancel_registration DateTime @db.Date
  race_result_api_status Int @default(0)
  start_bib_number Int    @default(0)
  api_url        String   @db.Text
  start_bib_number_used Int @default(0)
  label_1        String   @default("") @db.VarChar(255)
  label_2        String   @default("") @db.VarChar(255)
  value_1        String   @default("") @db.VarChar(255)
  send_warning_mail_member Int @default(0)
  rate_annulation_type Int @default(0)
  rate_handling_fee_paid Int @default(0)
  rate_handling_fee_for_refund Int @default(0)
  generate_friend_code Int @default(0)
  gallery_short_code String @default("") @db.VarChar(255)
  approval_status Int     @default(0)
  allow_donation Int      @default(0)
  charities_id   Int      @default(0)
  linked_to_activity_ranking String @default("") @db.VarChar(255)
  upload_rank_file_name String @default("") @db.VarChar(255)
  upload_rank_file_source String @default("") @db.VarChar(255)
  hours_ranking  Int      @default(0)
  minutes_ranking Int     @default(0)
  seconds_ranking Int     @default(0)
  hide_date_race Int      @default(0)
  advance_features Int    @default(0)
  quantity_updated_order_id Int @default(0)
  logo_series    String   @default("") @db.VarChar(500)
  logo_image     String   @default("") @db.VarChar(500)
  logo_image_mobile String @default("") @db.VarChar(500)
  downgrade_distance_credits DateTime @db.Date
  hide_title_date Int     @default(1)
  premium_data   String   @db.Text
  premium_data_big String @db.LongText
  show_premium_suggestion Int @default(0)
  premium_conditions_valid Int @default(0)
  last_minute    Int      @default(0)
  last_minute_fields String @default("") @db.VarChar(255)
  register_url   String   @default("") @db.VarChar(255)
  display_status Int      @default(0)
  manufacturer   String   @default("") @db.VarChar(255)
  product_show_reviews Int @default(0)
  is_room_reservation Int @default(0)
  product_allow_reviews Int @default(0)
  is_new_edition Int      @default(0)
  participant_list_open Int @default(0)
  fundraising_mandatory Int @default(0)
  minimumn_amt_charity Decimal @default(0) @db.Decimal(15, 4)
  formation_term Int      @default(0)
  individual_target_charity Int @default(0)
  refund_credit_fee_charity Int @default(0)
  end_date_charity DateTime @db.Date
  hide_admin_configure_charity Decimal @default(0) @db.Decimal(15, 4)
  hide_admin_configure_charity_percentage Decimal @default(0) @db.Decimal(15, 4)
  name_charity_id Int     @default(0)
  show_charity   Int      @default(0)
  charity_type   Int      @default(0)
  is_free_registration_donation Int @default(0)
  compensate_admin_fee Int @default(0)
  event_goal     Int      @default(0)
  combine_donation Int    @default(0)
  show_tombola   Int      @default(0)
  donation_amount_cal Decimal @default(0.00) @db.Decimal(10, 2)
  fast_checkout  Int      @default(0)
  auto_start_amount Decimal @default(0.00) @db.Decimal(10, 2)
  design         Int      @default(0)
  acti_v2_status Int      @default(0)

  acti_lite_price_type    String?  @db.VarChar(255)
