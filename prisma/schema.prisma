// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Brand ─────────────────────────────────────────────────────────────────────
model Brand {
  brand_id     Int           @id @default(autoincrement())
  brand_name   String        @db.VarChar(255)
  sort_order   Int           @default(0)

  menus        Menu[]
  products     Product[]
  heroBuilders HeroBuilder[]

  @@map("oc_brand")
}

// ── Menu ──────────────────────────────────────────────────────────────────────
model Menu {
  menu_id    Int      @id @default(autoincrement())
  brand_id   Int
  brand_name String   @db.VarChar(255)
  brand_logo String   @db.VarChar(255)
  event_id   Int?
  event_name String?  @db.VarChar(255)
  event_logo String?  @db.VarChar(255)

  brand        Brand         @relation(fields: [brand_id], references: [brand_id])
  tabs         MenuTab[]
  fields       MenuField[]
  heroBuilders HeroBuilder[]

  @@map("oc_menu")
}

enum NavType {
  brand
  event
}

// ── MenuTab ───────────────────────────────────────────────────────────────────
model MenuTab {
  id        Int     @id @default(autoincrement())
  tab_name  String  @db.VarChar(255)
  tab_icon  String? @db.VarChar(255)
  tab_image String? @db.VarChar(255)
  menu_id   Int
  nav_type  NavType
  num_cols  Int     @default(4)

  menu   Menu        @relation(fields: [menu_id], references: [menu_id])
  fields MenuField[]

  @@index([menu_id])
  @@map("oc_menu_tab")
}

enum oc_menu_2_field_nav_type {
  brand
  event
}

enum oc_menu_2_field_type {
  text
  image
  icon
}

enum oc_menu_2_field_col_type {
  text
  image
  icon
}

enum oc_menu_2_field_icon_sub_type {
  vertical
  horizontal
  contact
}

enum oc_menu_2_field_extra_type {
  social
  text_block
}

// ── MenuField ─────────────────────────────────────────────────────────────────
model MenuField {
  id                 Int                            @id @default(autoincrement())
  menu_id            Int
  tab_id             Int
  nav_type           oc_menu_2_field_nav_type       @default(brand)
  column             Int?
  label              String?                        @db.VarChar(255)
  link_en            String?                        @db.VarChar(255)
  link_fr            String?                        @db.VarChar(255)
  link_nl            String?                        @db.VarChar(255)
  type               oc_menu_2_field_type?
  icon_color         String?                        @db.VarChar(20)
  icon_background    String?                        @db.VarChar(20)
  language_id        Int?
  image              String?                        @db.VarChar(500)
  icon               String?                        @db.VarChar(100)
  section_heading_en String?                        @db.VarChar(255)
  section_heading_nl String?                        @db.VarChar(255)
  section_heading_fr String?                        @db.VarChar(255)
  section_link_en    String?                        @db.VarChar(500)
  section_link_nl    String?                        @db.VarChar(500)
  section_link_fr    String?                        @db.VarChar(500)
  col_type           oc_menu_2_field_col_type?
  icon_sub_type      oc_menu_2_field_icon_sub_type?
  contact_title      String?                        @db.VarChar(255)
  contact_body       String?                        @db.Text
  contact_link_label String?                        @db.VarChar(255)
  contact_link_url   String?                        @db.VarChar(500)
  extra_type         oc_menu_2_field_extra_type?
  social_fb          String?                        @db.VarChar(500)
  social_tt          String?                        @db.VarChar(500)
  social_ig          String?                        @db.VarChar(500)
  text_block_title   String?                        @db.VarChar(255)
  text_block_body    String?                        @db.Text
  sort_order         Int                            @default(0)
  num_cols           Int                            @default(1)

  menu Menu    @relation(fields: [menu_id], references: [menu_id])
  tab  MenuTab @relation(fields: [tab_id], references: [id])

  @@index([menu_id])
  @@index([tab_id])
  @@index([column])
  @@map("oc_menu_2_field")
}

// ── HeroBuilder ───────────────────────────────────────────────────────────────
model HeroBuilder {
  hero_id         Int       @id @default(autoincrement())
  brand_id        Int
  event_id        Int
  distance_id     Int?
  distance_name   String?   @db.VarChar(100)
  bg_img          String?   @db.LongText
  mobile_background_image String? @db.VarChar(255) 
  race_photo      String?   @db.LongText
  badge_img       String?   @db.LongText
  brand_logo_img  String?   @db.LongText
  overlay_color   String?   @default("#0D1F35") @db.VarChar(20)
  overlay_opacity Int?      @default(40)
  event_name      String?   @db.VarChar(255)
  breadcrumb      String?   @db.Text
  distance        String?   @db.VarChar(100)
  elevation       String?   @db.VarChar(100)
  description     String?   @db.Text
  tagline         String?   @db.Text
  badge_bg        String?   @default("#F5C300") @db.VarChar(20)
  show_brand_logo Boolean?  @default(true) @db.TinyInt
  dist_color      String?   @default("#FFFFFF") @db.VarChar(20)
  sidebar_stats   String?   @db.LongText
  bottom_stats    String?   @db.LongText
  cta_buttons     String?   @db.LongText
  race_date       DateTime? @db.Date
  race_time       String?   @db.VarChar(10)
  race_waves      Int       @default(1) @db.TinyInt
  sold_out        Boolean   @default(false) @db.TinyInt
  created_at      DateTime? @default(now()) @db.Timestamp(0)
  updated_at      DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  menu_id         Int?

  brand Brand  @relation(fields: [brand_id], references: [brand_id])
  event Product @relation(fields: [event_id], references: [product_id])
  menu  Menu?  @relation(fields: [menu_id], references: [menu_id])

  @@index([event_id])
  @@map("hero_builder")
}

// ── Product ───────────────────────────────────────────────────────────────────
model Product {
  product_id     Int      @id @default(autoincrement())
  model          String   @db.VarChar(64)
  date_reg_close DateTime @db.Date
  date_race      DateTime @db.Date
  date_reg_change DateTime @db.Date
