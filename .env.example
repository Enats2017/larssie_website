# ============================================
# DATABASE CONNECTION IS DEFINED HERE (.env)
# ============================================
# This file is NEVER uploaded to GitHub!
# Add this file manually on every server/machine

# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DBNAME

DATABASE_URL="mysql://root:root@localhost:3306/db_larssie_live"

# ---- Examples ----

# Local MySQL (XAMPP / WAMP / MAMP):
# DATABASE_URL="mysql://root:root@localhost:3306/mydb"
# DATABASE_URL="mysql://root:@localhost:3306/mydb"        ← no password

# Local MySQL (custom user):
# DATABASE_URL="mysql://myuser:mypassword@localhost:3306/mydb"

# Remote MySQL server (VPS):
# DATABASE_URL="mysql://root:password@123.456.789.0:3306/mydb"

# PlanetScale (serverless MySQL):
# DATABASE_URL="mysql://[USER]:[PASSWORD]@[HOST]/[DBNAME]?sslaccept=strict"

# Railway (MySQL):
# DATABASE_URL="mysql://root:[PASSWORD]@[HOST]:3306/railway"